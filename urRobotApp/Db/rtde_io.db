record(ao, "$(P)IO:SpeedSlider")
{
    field(DESC, "Speed slider value(percentage)")
    field(DTYP, "asynFloat64")
    field(PINI, "1")
    field(VAL, "0.5")
    field(DRVH, "1.0")
    field(DRVL, "0.0")
    field(OUT,  "@asyn($(PORT),0,$(TIMEOUT=1))SPEED_SLIDER")
}

record(bo, "$(P)IO:SetStandardDO0")
{
    field(DESC, "Standard digital output 0")
    field(ZNAM,"LO")
    field(ONAM,"HI")
    field(DTYP, "asynInt32")
